# Copy this file to `.env` and adjust if needed:
#   cp .env.example .env
#
# On first clone, set UID/GID to match your host user so the rootless
# Dev Container (userns_mode: "keep-id") maps you 1:1 into the container.
# Generate them with:
#   printf 'UID=%s\nGID=%s\n' "$(id -u)" "$(id -g)" > .env

# --- Host user mapping (Dev Container) ---
UID=1000
GID=1000

# --- Backend service / SurrealDB ---
# These are also set by docker-compose.yml for the container. Listed here
# for running a service directly on the host (outside the container).
SURREAL_URL=ws://localhost:8000
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=opcaq
APQP_PORT=8081
RUST_LOG=apqp_service=debug,tower_http=info
