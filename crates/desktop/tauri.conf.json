{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LAST Stack Tasks",
  "version": "0.1.0",
  "identifier": "com.laststack.tasks",
  "build": {
    "beforeDevCommand": "sh -c 'cd /home/ingo/Development/LAST-Stack/crates/frontend && trunk serve'",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "sh -c 'cd /home/ingo/Development/LAST-Stack/crates/frontend && trunk build'",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LAST Stack — Task Management",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}