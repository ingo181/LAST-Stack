FROM rust:1.95-bookworm

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    build-essential \
    curl \
    git \
    cmake \
    libsasl2-dev \
    && rm -rf /var/lib/apt/lists/*

RUN rustup target add wasm32-unknown-unknown && rustup component add rust-src
RUN cargo install trunk cargo-watch

ARG UID=1000
ARG GID=1000
RUN groupadd -g ${GID} dev && \
    useradd -u ${UID} -g dev -m -s /bin/bash dev

RUN chown -R ${UID:-1000}:${GID:-1000} /usr/local/cargo
USER dev
WORKDIR /workspace

ENV CARGO_HOME=/usr/local/cargo
ENV PATH="/usr/local/cargo/bin:${PATH}"

CMD ["sleep", "infinity"]
